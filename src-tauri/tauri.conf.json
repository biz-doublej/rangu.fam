{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RanguTactics",
  "version": "0.1.0",
  "identifier": "fam.rangu.tactics",
  "build": {
    "frontendDist": "frontend",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "랑구 택틱스 — Rangu Tactics",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
