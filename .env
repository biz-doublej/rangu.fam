# =============================================================================
# RangU.FAM Environment Configuration
# =============================================================================
# This file contains all environment variables used throughout the application
# Copy this file to .env.local for local development
# DO NOT commit this file with real values to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# MongoDB connection string
# For local development, use: mongodb://localhost:27017/rangu-fam
# For production, use MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://gabrieljay0727:1234@cluster0.x1swcgo.mongodb.net/

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
# Secret key for JWT token signing and verification
# Used across the entire application for authentication
# Generate a strong random string for production
JWT_SECRET=rangu-fam-super-secret-key-2025-dev

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Base URL of the application
# Used for generating invite links, redirects, and absolute URLs
# For local development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Environment mode (development, production, test)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Discord Integration
# -----------------------------------------------------------------------------
# Discord webhook URL for sending notifications
# Used by DiscordWebhookService for various notifications
# Get this from your Discord server webhook settings
# Currently hardcoded in the service, but should be moved here for security
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Alternative Discord webhook for different channels (optional)
DISCORD_WEBHOOK_URL_ADMIN=https://discord.com/api/webhooks/YOUR_ADMIN_WEBHOOK_ID/YOUR_ADMIN_WEBHOOK_TOKEN

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# Maximum file size for uploads (in bytes)
# Current default: 5MB = 5 * 1024 * 1024
MAX_FILE_SIZE=5242880

# Allowed image MIME types (comma-separated)
ALLOWED_MIME_TYPES=image/jpeg,image/jpg,image/png,image/gif,image/webp,image/svg+xml

# -----------------------------------------------------------------------------
# Wiki Configuration
# -----------------------------------------------------------------------------
# Wiki-specific settings
WIKI_RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds
WIKI_MAX_REQUESTS=10           # Maximum requests per window
WIKI_LOCK_DURATION=600000      # 10 minutes in milliseconds

# -----------------------------------------------------------------------------
# Game Configuration
# -----------------------------------------------------------------------------
# Tetris game session configuration
TETRIS_SESSION_TIMEOUT=3600000 # 1 hour in milliseconds
TETRIS_MAX_PLAYERS=8           # Maximum players per game session

# -----------------------------------------------------------------------------
# Card System Configuration
# -----------------------------------------------------------------------------
# Card drop system settings
CARD_DROP_DAILY_LIMIT=5        # Maximum daily card drops per user
CARD_DROP_RESET_HOUR=0         # Hour of day when drops reset (0-23, UTC)

# Card crafting settings
CARD_CRAFT_SUCCESS_RATE=0.7    # 70% success rate for crafting
CARD_MAX_INVENTORY=1000        # Maximum cards per user inventory

# -----------------------------------------------------------------------------
# Email Configuration (if email features are added)
# -----------------------------------------------------------------------------
# SMTP configuration for sending emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@rangu-fam.com

# -----------------------------------------------------------------------------
# External API Keys (if external services are used)
# -----------------------------------------------------------------------------
# OpenAI API key (if AI features are added)
# OPENAI_API_KEY=your-openai-api-key

# Google Analytics (if analytics are added)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry (if error tracking is added)
# SENTRY_DSN=your-sentry-dsn
# NEXT_PUBLIC_SENTRY_DSN=your-public-sentry-dsn

# -----------------------------------------------------------------------------
# Development & Debug Configuration
# -----------------------------------------------------------------------------
# Enable detailed logging in development
DEBUG=true
LOG_LEVEL=info

# Enable debug routes and features
ENABLE_DEBUG_ROUTES=true

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://rangu-fam.vercel.app

# Session configuration
SESSION_SECRET=rangu-fam-session-secret-key
SESSION_MAX_AGE=604800000      # 7 days in milliseconds

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100    # Max requests per IP per window

# -----------------------------------------------------------------------------
# Performance Configuration
# -----------------------------------------------------------------------------
# Next.js build configuration
NEXT_TELEMETRY_DISABLED=1      # Disable Next.js telemetry
ANALYZE=false                  # Enable bundle analyzer

# Memory limits
NODE_OPTIONS=--max-old-space-size=4096

# -----------------------------------------------------------------------------
# Monitoring & Analytics (Optional)
# -----------------------------------------------------------------------------
# Application monitoring
# MONITORING_ENDPOINT=your-monitoring-endpoint
# MONITORING_API_KEY=your-monitoring-api-key

# Performance monitoring
# PERFORMANCE_MONITORING=true
# PERFORMANCE_SAMPLE_RATE=0.1

# =============================================================================
# Environment-Specific Overrides
# =============================================================================
# Copy this file to:
# - .env.local (for local development)
# - .env.production (for production deployment)
# - .env.test (for testing)
# 
# And modify the values according to your environment needs.
# =============================================================================