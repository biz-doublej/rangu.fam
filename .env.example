# App mode
AUTH_MODE="sso"
NODE_ENV="production"

# Core secrets
JWT_SECRET="replace-me"
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="https://your-domain.com"

# Database
# App DB connection goes through PostgreSQL-backed bridge endpoint.
POSTGRES_BRIDGE_URI="<SET_FERRETDB_ENDPOINT_URI>"

# Native PostgreSQL URL (used in phase-2 migration)
DATABASE_URL="postgresql://rangu_app:change-me-strong-password@localhost:5432/rangu_fam"

# Wiki uploads storage
# Set NAS mount path in production (example: /mnt/nas/wiki-uploads or Z:\\wiki-uploads)
WIKI_UPLOADS_DIR=""

# Discord / SSO integration
# Service OIDC (required)
OIDC_ISSUER="https://auth.doublej.app"
OIDC_CLIENT_ID="replace-me"
OIDC_CLIENT_SECRET="replace-me"
OIDC_REDIRECT_URI="https://your-domain.com/auth/callback"
OIDC_SCOPE="openid profile email offline_access"
ACCOUNTS_BASE_URL="https://accounts.doublej.app"
NEXT_PUBLIC_ACCOUNTS_BASE_URL="https://accounts.doublej.app"

# Legacy Discord link flow (optional)
DISCORD_CLIENT_ID="replace-me"
DISCORD_CLIENT_SECRET="replace-me"
DISCORD_REDIRECT_BASE_URL="https://your-domain.com"
DISCORD_WEBHOOK_URL=""
DISCORD_ADMIN_WEBHOOK_URL=""
DISCORD_USER_WEBHOOK_URL=""

# AWS (fill only if you use AWS services directly)
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_DOMAIN=""
