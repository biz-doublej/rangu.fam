# Legacy local override example.
# Preferred setup: copy `.env.example` to `.env` and manage sensitive keys there.

# Shared
JWT_SECRET="replace-me"
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"

# Auth mode
# - sso: local login/register API disabled (recommended for DoubleJ SSO integration)
# - legacy: keep existing local auth APIs
AUTH_MODE="sso"

# DB mode
# Current migration strategy:
# PostgreSQL is the single data store, and app keeps legacy API compatibility via FerretDB.
# Run infra/postgres-bridge/docker-compose.yml, then point POSTGRES_BRIDGE_URI to FerretDB.
POSTGRES_BRIDGE_URI="<SET_FERRETDB_ENDPOINT_URI>"

# Optional direct PostgreSQL URL (for upcoming native SQL migration stage)
DATABASE_URL="postgresql://rangu_app:change-me-strong-password@localhost:5432/rangu_fam"

# Wiki uploads storage
# Leave empty in local dev to use ./public/uploads/wiki
# In production, set this to NAS mount path.
WIKI_UPLOADS_DIR=""

DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
DISCORD_REDIRECT_BASE_URL=""
DISCORD_WEBHOOK_URL=""
DISCORD_ADMIN_WEBHOOK_URL=""
DISCORD_USER_WEBHOOK_URL=""

# Service OIDC (required for login/signup/account integration)
OIDC_ISSUER="https://auth.doublej.app"
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_REDIRECT_URI="http://localhost:3000/auth/callback"
OIDC_SCOPE="openid profile email offline_access"
ACCOUNTS_BASE_URL="https://accounts.doublej.app"
NEXT_PUBLIC_ACCOUNTS_BASE_URL="https://accounts.doublej.app"

# AWS (used when connecting AWS services directly)
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_CLOUDFRONT_DOMAIN=""
